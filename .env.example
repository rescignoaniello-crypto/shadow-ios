# ═══════════════════════════════════════════════════════
# SHADOW iOS — Environment Variables (TEMPLATE)
# ═══════════════════════════════════════════════════════
# Copiar este archivo a .env y llenar con valores reales:
#   cp .env.example .env

# ── Supabase (shadow-ios project) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── n8n ────────────────────────────────────────────────
N8N_URL=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key

# ── Evolution API (WhatsApp) ───────────────────────────
EVOLUTION_URL=https://your-evolution-api.com
EVOLUTION_INSTANCE_PRUEBA=prueba
EVOLUTION_API_KEY_PRUEBA=your-evolution-api-key-prueba
EVOLUTION_INSTANCE_CORRECCIONES=correcciones
EVOLUTION_API_KEY_CORRECCIONES=your-evolution-api-key-correcciones

# ── Shopify ────────────────────────────────────────────
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your-shopify-client-id
# NOTA: Shopify usa OAuth2 via credencial en n8n

# ── Admin ──────────────────────────────────────────────
ADMIN_WHATSAPP=your-admin-phone-number

# ── Grupos WhatsApp ────────────────────────────────────
GROUP_DASHBOARD=your-dashboard-group-id@g.us
GROUP_PYP=your-pyp-group-id@g.us
GROUP_POLARIS=your-polaris-group-id@g.us
